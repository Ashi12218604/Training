@model IEnumerable<MVCdotnet_Age.Models.Student>

<h2>Students List</h2>

<table border="1" cellpadding="8">
    <tr>
      
        <th>Name</th>
        <th>Age</th>
       
    </tr>

    @foreach (var s in Model)
    {
        <tr>
          
            <td>@s.Name</td>
            <td>@s.Age</td>
            
        </tr>
    }
</table>