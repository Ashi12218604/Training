@model StudentManagement.Models.Student

<div style="width:350px;border:2px solid black;padding:15px;border-radius:10px">

    <h3 style="text-align:center">Student ID Card</h3>

    <p><strong>ID:</strong> @Model.StudentId</p>
    <p><strong>Name:</strong> @Model.Name</p>
    <p><strong>Email:</strong> @Model.Email</p>
    <p><strong>Course:</strong> @Model.Course</p>
    <p><strong>Semester:</strong> @Model.Semester</p>

</div>