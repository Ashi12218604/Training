@{
    ViewData["Title"] = "Login";
}

<h2>Student Login</h2>

<form method="post">
    <div>
        <label>Student ID</label>
        <input type="text" name="StudentId" required />
    </div>

    <div>
        <label>Password</label>
        <input type="password" name="Password" required />
    </div>

    <br />

    <button type="submit">Login</button>
</form>