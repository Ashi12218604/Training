@model OnetoMany.Models.Student

<h2>Create Student</h2>

<form method="post">

    <label>Name</label>
    <input asp-for="Name" />

    <br />

    <label>Department</label>
    <select asp-for="DepartmentId" asp-items="ViewBag.Departments">
    </select>

    <br />

    <button type="submit">Save</button>

</form>